POSTGRES_USER=postgres
POSTGRES_PASSWORD=traceforge123
POSTGRES_DB=traceforge
DATABASE_URL=postgresql://postgres:traceforge123@db:5432/traceforge?schema=public
REDIS_URL=redis://redis:6379
BACKEND_PORT=3001
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET=your_super_secret_jwt_key_here_32chars_min

# Public URL (optional, used in redirects)
APP_PUBLIC_URL=http://localhost:3000

# TraceForge dogfooding (optional)
# Use TraceForge inside TraceForge to see live frontend/backend errors in your own dashboard.
# Steps:
# 1) Create a project in TraceForge (Dashboard → Projects) and copy its Project API key.
# 2) Paste it into TRACEFORGE_PROJECT_KEY.
TRACEFORGE_INGEST_URL=http://localhost:3001/ingest
TRACEFORGE_PROJECT_KEY=
TRACEFORGE_PROXY_PATH=/api/traceforge/ingest
TRACEFORGE_DOGFOODING=true
APP_ENV=local
APP_RELEASE=traceforge@dev
NEXT_PUBLIC_TRACEFORGE_PROXY_PATH=/api/traceforge/ingest
# Must be "true" to enable browser error capture.
NEXT_PUBLIC_TRACEFORGE_DOGFOODING=true

# Razorpay billing (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Create a Razorpay Plan in Dashboard (Subscriptions) and paste its plan_id here.
# Launch plan (₹299/mo) used for early adopters.
RAZORPAY_PLAN_PRO_MONTHLY_ID=
# Standard plan (₹499/mo) used after launch slots are filled.
RAZORPAY_PLAN_PRO_MONTHLY_STANDARD_ID=
# Number of early-adopter slots (default 20).
PRO_LAUNCH_SLOTS=20
# Webhook secret you set while creating the webhook in Razorpay Dashboard.
RAZORPAY_WEBHOOK_SECRET=

# FX rates for pricing display (optional)
# Default provider: currencyapi if CURRENCYAPI_API_KEY is set, otherwise frankfurter (daily rates).
FX_PROVIDER=
FX_CACHE_TTL_SECONDS=300
CURRENCYAPI_API_KEY=
