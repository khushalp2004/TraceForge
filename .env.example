POSTGRES_USER=postgres
POSTGRES_PASSWORD=traceforge123
POSTGRES_DB=traceforge
DATABASE_URL=postgresql://postgres:traceforge123@db:5432/traceforge?schema=public
REDIS_URL=redis://redis:6379
BACKEND_PORT=3001
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=groq/compound
JWT_SECRET=your_super_secret_jwt_key_here_32chars_min

# Public URL (optional, used in redirects)
APP_PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/auth/github/callback

# Workspace integrations (optional)
INTEGRATIONS_ENCRYPTION_KEY=replace_with_a_long_random_secret

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3001/integrations/slack/callback

# Jira OAuth
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3001/integrations/jira/callback

# Razorpay billing (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Create a Razorpay Plan in Dashboard (Subscriptions) and paste its plan_id here.
# Launch plan (₹399/mo) used for the first 20 Pro customers.
RAZORPAY_PLAN_PRO_MONTHLY_ID=
# Standard plan (₹599/mo) used after launch slots are filled.
RAZORPAY_PLAN_PRO_MONTHLY_STANDARD_ID=
# Launch yearly Pro plan (₹3,588/yr) used for early adopters.
RAZORPAY_PLAN_PRO_YEARLY_ID=
# Standard yearly Pro plan (₹5,988/yr) used after launch slots are filled.
RAZORPAY_PLAN_PRO_YEARLY_STANDARD_ID=
# Team plan (₹799/mo).
RAZORPAY_PLAN_TEAM_MONTHLY_ID=
# Team yearly plan (₹8,388/yr).
RAZORPAY_PLAN_TEAM_YEARLY_ID=
# Number of early-adopter slots (default 20).
PRO_LAUNCH_SLOTS=20
# Webhook secret you set while creating the webhook in Razorpay Dashboard.
RAZORPAY_WEBHOOK_SECRET=

# FX rates for pricing display (optional)
# Default provider: currencyapi if CURRENCYAPI_API_KEY is set, otherwise frankfurter (daily rates).
FX_PROVIDER=
FX_CACHE_TTL_SECONDS=300
CURRENCYAPI_API_KEY=
