{
  "name": "traceforge",
  "displayName": "TraceForge",
  "description": "Initialize TraceForge error monitoring in your workspace.",
  "version": "0.0.1",
  "publisher": "traceforge",
  "repository": {
    "type": "git",
    "url": "https://github.com/khushalp2004/TraceForge.git",
    "directory": "tools/traceforge-vscode-extension"
  },
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:traceforge.configure",
    "onCommand:traceforge.initialize"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "traceforge.configure",
        "title": "TraceForge: Configure"
      },
      {
        "command": "traceforge.initialize",
        "title": "TraceForge: Initialize in Workspace"
      }
    ],
    "configuration": {
      "title": "TraceForge",
      "properties": {
        "traceforge.ingestUrl": {
          "type": "string",
          "default": "http://localhost:3001/ingest",
          "description": "TraceForge ingest URL."
        },
        "traceforge.backendProxyPath": {
          "type": "string",
          "default": "/api/traceforge/ingest",
          "description": "Backend proxy path used by the frontend integration."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json -w"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
