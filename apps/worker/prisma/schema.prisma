generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  fullName             String?
  address              String?
  email                String                 @unique
  passwordHash         String
  plan                 BillingPlan            @default(FREE)
  planInterval         PlanInterval?
  subscriptionStatus   String?
  planExpiresAt        DateTime?
  createdAt            DateTime               @default(now())
  projects             Project[]
  alertRules           AlertRule[]
  memberships          OrganizationMember[]
  invitations          OrganizationInvite[]   @relation("Invitee")
  auditEvents          OrgAuditLog[]          @relation("Actor")
  resetTokens          PasswordResetToken[]
  joinRequests         OrgJoinRequest[]       @relation("Requester")
  resolvedJoinRequests OrgJoinRequest[]       @relation("Resolver")
}

enum BillingPlan {
  FREE
  PRO
  TEAM
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id           String               @id @default(cuid())
  name         String
  createdAt    DateTime             @default(now())
  plan         BillingPlan          @default(FREE)
  planInterval PlanInterval?
  subscriptionStatus String?
  planExpiresAt DateTime?
  members      OrganizationMember[]
  projects     Project[]
  invites      OrganizationInvite[]
  auditLogs    OrgAuditLog[]
  joinRequests OrgJoinRequest[]

  @@index([createdAt])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

enum OrgRole {
  OWNER
  MEMBER
}

model OrganizationInvite {
  id             String   @id @default(cuid())
  organizationId String
  token          String   @unique
  role           OrgRole  @default(MEMBER)
  email          String?
  createdById    String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("Invitee", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([expiresAt])
}

model OrgAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User?        @relation("Actor", fields: [actorId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrgJoinRequest {
  id             String            @id @default(cuid())
  organizationId String
  requesterId    String
  inviteToken    String?
  role           OrgRole           @default(MEMBER)
  status         JoinRequestStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  resolvedById   String?

  organization Organization @relation(fields: [organizationId], references: [id])
  requester    User         @relation("Requester", fields: [requesterId], references: [id])
  resolvedBy   User?        @relation("Resolver", fields: [resolvedById], references: [id])

  @@index([organizationId])
  @@index([requesterId])
  @@index([status])
}

model Project {
  id              String          @id @default(cuid())
  userId          String
  orgId           String?
  name            String
  apiKey          String          @unique
  aiModel         String          @default("groq/compound")
  createdAt       DateTime        @default(now())
  archivedAt      DateTime?

  user            User            @relation(fields: [userId], references: [id])
  org             Organization?   @relation(fields: [orgId], references: [id])
  errors          Error[]
  alertRules      AlertRule[]
  alertDeliveries AlertDelivery[]
  releases        Release[]

  @@index([archivedAt])
  @@index([orgId])
}

model Error {
  id              String          @id @default(cuid())
  projectId       String
  message         String
  stackTrace      String
  hash            String
  firstSeen       DateTime        @default(now())
  lastSeen        DateTime        @default(now())
  count           Int             @default(1)
  archivedAt      DateTime?
  aiStatus        ErrorAiStatus   @default(PENDING)
  aiLastError     String?
  aiRequestedAt   DateTime?
  aiRequestedByUserId String?
  aiCompletedAt   DateTime?

  project         Project         @relation(fields: [projectId], references: [id])
  events          ErrorEvent[]
  analysis        ErrorAnalysis?
  alertDeliveries AlertDelivery[]

  @@unique([projectId, hash])
  @@index([archivedAt])
  @@index([projectId])
  @@index([lastSeen])
}

model ErrorEvent {
  id          String   @id @default(cuid())
  errorId     String
  releaseId   String?
  timestamp   DateTime @default(now())
  environment String?
  payload     Json?

  error Error @relation(fields: [errorId], references: [id])
  release Release? @relation(fields: [releaseId], references: [id])

  @@index([errorId])
  @@index([releaseId])
}

model ErrorAnalysis {
  id            String   @id @default(cuid())
  errorId       String   @unique
  aiExplanation String
  suggestedFix  String?
  createdAt     DateTime @default(now())

  error Error @relation(fields: [errorId], references: [id])
}

enum ErrorAiStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertChannel {
  IN_APP
}

enum ReleaseSource {
  MANUAL
  INGEST
}

model Release {
  id          String        @id @default(cuid())
  projectId   String
  version     String
  environment String?
  notes       String?
  source      ReleaseSource @default(MANUAL)
  releasedAt  DateTime      @default(now())
  createdAt   DateTime      @default(now())

  project Project      @relation(fields: [projectId], references: [id])
  events  ErrorEvent[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([releasedAt])
}

model AlertRule {
  id              String        @id @default(cuid())
  userId          String
  projectId       String?
  name            String
  environment     String?
  severity        AlertSeverity @default(CRITICAL)
  minOccurrences  Int           @default(1)
  cooldownMinutes Int           @default(30)
  channel         AlertChannel  @default(IN_APP)
  isActive        Boolean       @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  archivedAt      DateTime?

  user       User            @relation(fields: [userId], references: [id])
  project    Project?        @relation(fields: [projectId], references: [id])
  deliveries AlertDelivery[]

  @@index([archivedAt])
  @@index([userId])
  @@index([projectId])
  @@index([isActive])
}

model AlertDelivery {
  id          String    @id @default(cuid())
  alertRuleId String
  projectId   String
  errorId     String
  environment String?
  message     String
  triggeredAt DateTime  @default(now())

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id])
  error     Error     @relation(fields: [errorId], references: [id])

  @@index([alertRuleId])
  @@index([projectId])
  @@index([errorId])
  @@index([triggeredAt])
}
