generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                 @id @default(cuid())
  fullName     String?
  address      String?
  email        String                 @unique
  passwordHash String
  emailVerifiedAt DateTime?
  disabledAt   DateTime?
  disabledReason String?
  createdAt    DateTime               @default(now())
  plan         BillingPlan            @default(FREE)
  planInterval PlanInterval?
  proPricingTier ProPricingTier?
  subscriptionStatus String?
  planExpiresAt DateTime?
  lastPaymentProvider String?
  lastPaymentId String?
  razorpaySubscriptionId String?
  projects     Project[]
  alertRules   AlertRule[]
  memberships  OrganizationMember[]
  invitations  OrganizationInvite[]   @relation("Invitee")
  auditEvents  OrgAuditLog[]          @relation("Actor")
  resetTokens  PasswordResetToken[]
  verificationCodes EmailVerificationCode[]
  joinRequests OrgJoinRequest[]       @relation("Requester")
  resolvedJoinRequests OrgJoinRequest[] @relation("Resolver")
  payments     Payment[]
  notificationDismissals NotificationDismissal[]
  integrationConnections IntegrationConnection[]
  aiUsageEntries AiUsageEntry[]
}

enum BillingPlan {
  FREE
  DEV
  PRO
  TEAM
}

enum ProPricingTier {
  LAUNCH
  STANDARD
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

model Payment {
  id                String      @id @default(cuid())
  userId            String
  organizationId    String?
  provider          String
  plan              BillingPlan
  interval          PlanInterval?
  amount            Int
  currency          String
  status            String
  razorpayOrderId   String?     @unique
  razorpaySubscriptionId String?
  razorpayPaymentId String?     @unique
  capturedAt        DateTime?
  expiresAt         DateTime?
  payload           Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([provider, status])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id        String                 @id @default(cuid())
  name      String
  createdAt DateTime               @default(now())
  plan      BillingPlan            @default(FREE)
  planInterval PlanInterval?
  subscriptionStatus String?
  planExpiresAt DateTime?
  lastPaymentProvider String?
  lastPaymentId String?
  razorpaySubscriptionId String?
  members   OrganizationMember[]
  projects  Project[]
  invites   OrganizationInvite[]
  auditLogs OrgAuditLog[]
  joinRequests OrgJoinRequest[]
  payments  Payment[]
  integrationConnections IntegrationConnection[]
  aiUsageEntries AiUsageEntry[]

  @@index([createdAt])
}

model OrganizationMember {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole        @default(MEMBER)
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

enum OrgRole {
  OWNER
  MEMBER
}

model OrganizationInvite {
  id             String   @id @default(cuid())
  organizationId String
  token          String   @unique
  role           OrgRole  @default(MEMBER)
  email          String?
  createdById    String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("Invitee", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([expiresAt])
  @@index([organizationId, expiresAt])
}

model OrgAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User?        @relation("Actor", fields: [actorId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrgJoinRequest {
  id             String             @id @default(cuid())
  organizationId String
  requesterId    String
  inviteToken    String?
  role           OrgRole            @default(MEMBER)
  status         JoinRequestStatus  @default(PENDING)
  createdAt      DateTime           @default(now())
  resolvedAt     DateTime?
  resolvedById   String?

  organization Organization @relation(fields: [organizationId], references: [id])
  requester    User         @relation("Requester", fields: [requesterId], references: [id])
  resolvedBy   User?        @relation("Resolver", fields: [resolvedById], references: [id])

  @@index([organizationId])
  @@index([requesterId])
  @@index([status])
  @@index([organizationId, status, createdAt])
}

model Project {
  id               String    @id @default(cuid())
  userId           String
  orgId            String?
  name             String
  apiKey           String    @unique
  aiModel          String    @default("groq/compound")
  githubRepoId     String?
  githubRepoName   String?
  githubRepoUrl    String?
  createdAt        DateTime  @default(now())
  archivedAt       DateTime?
  configuredAt     DateTime?
  lastConfiguredAt DateTime?

  user   User          @relation(fields: [userId], references: [id])
  org    Organization? @relation(fields: [orgId], references: [id])
  errors Error[]
  alertRules AlertRule[]
  alertDeliveries AlertDelivery[]
  releases Release[]
  githubRepoAnalysis GithubRepoAnalysis?
  aiUsageEntries AiUsageEntry[]

  @@index([archivedAt])
  @@index([orgId])
  @@index([userId, archivedAt, createdAt])
  @@index([orgId, archivedAt, createdAt])
}

model Error {
  id         String   @id @default(cuid())
  projectId  String
  message    String
  stackTrace String
  hash       String
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  count      Int      @default(1)
  archivedAt DateTime?
  aiStatus   ErrorAiStatus @default(PENDING)
  aiLastError String?
  aiRequestedAt DateTime?
  aiRequestedByUserId String?
  aiCompletedAt DateTime?

  project  Project       @relation(fields: [projectId], references: [id])
  events   ErrorEvent[]
  analysis ErrorAnalysis?
  alertDeliveries AlertDelivery[]

  @@unique([projectId, hash])
  @@index([archivedAt])
  @@index([projectId])
  @@index([lastSeen])
  @@index([projectId, archivedAt, lastSeen])
  @@index([projectId, archivedAt, count])
}

model ErrorEvent {
  id          String   @id @default(cuid())
  errorId     String
  releaseId   String?
  timestamp   DateTime @default(now())
  environment String?
  payload     Json?

  error Error @relation(fields: [errorId], references: [id])
  release Release? @relation(fields: [releaseId], references: [id])

  @@index([errorId])
  @@index([releaseId])
  @@index([errorId, timestamp])
  @@index([timestamp, environment])
}

model ErrorAnalysis {
  id            String   @id @default(cuid())
  errorId       String   @unique
  aiExplanation String
  suggestedFix  String?
  createdAt     DateTime @default(now())

  error Error @relation(fields: [errorId], references: [id])
}

enum GithubRepoAnalysisStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model GithubRepoAnalysis {
  id               String                   @id @default(cuid())
  projectId        String                   @unique
  repoId           String
  repoName         String
  repoUrl          String?
  status           GithubRepoAnalysisStatus @default(PENDING)
  model            String?
  summary          String?
  architecture     String?
  runtimeFlow      String?
  developmentFlow  String?
  techStack        Json?
  keyModules       Json?
  entryPoints      Json?
  risks            Json?
  onboardingTips   Json?
  lastError        String?
  generatedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([generatedAt])
}

enum ErrorAiStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertChannel {
  IN_APP
}

enum NotificationDismissalKind {
  ALERT
  INVITE
  JOIN_REQUEST
}

enum IntegrationProvider {
  GITHUB
  SLACK
  JIRA
  PAGERDUTY
}

enum IntegrationScope {
  USER
  ORGANIZATION
}

enum IntegrationStatus {
  CONNECTED
  ERROR
}

enum AiUsageKind {
  GITHUB_REPO_ANALYSIS
}

enum ReleaseSource {
  MANUAL
  INGEST
}

model Release {
  id          String        @id @default(cuid())
  projectId   String
  version     String
  environment String?
  notes       String?
  source      ReleaseSource @default(MANUAL)
  releasedAt  DateTime      @default(now())
  createdAt   DateTime      @default(now())

  project Project      @relation(fields: [projectId], references: [id])
  events  ErrorEvent[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([releasedAt])
  @@index([projectId, releasedAt])
}

model AlertRule {
  id               String        @id @default(cuid())
  userId           String
  projectId        String?
  name             String
  issueDescription String?
  environment      String?
  severity         AlertSeverity @default(CRITICAL)
  minOccurrences   Int           @default(1)
  cooldownMinutes  Int           @default(30)
  channel          AlertChannel  @default(IN_APP)
  isActive         Boolean       @default(true)
  lastTriggeredAt  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  archivedAt       DateTime?

  user       User            @relation(fields: [userId], references: [id])
  project    Project?        @relation(fields: [projectId], references: [id])
  deliveries AlertDelivery[]

  @@index([archivedAt])
  @@index([userId])
  @@index([projectId])
  @@index([isActive])
  @@index([userId, archivedAt, isActive])
  @@index([projectId, archivedAt, isActive])
}

model AlertDelivery {
  id           String      @id @default(cuid())
  alertRuleId  String
  projectId    String
  errorId      String
  environment  String?
  message      String
  triggeredAt  DateTime    @default(now())

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id])
  error     Error     @relation(fields: [errorId], references: [id])

  @@index([alertRuleId])
  @@index([projectId])
  @@index([errorId])
  @@index([triggeredAt])
  @@index([projectId, triggeredAt])
  @@index([errorId, triggeredAt])
  @@index([alertRuleId, triggeredAt])
}

model NotificationDismissal {
  id              String                    @id @default(cuid())
  userId          String
  kind            NotificationDismissalKind
  notificationKey String
  createdAt       DateTime                  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, notificationKey])
  @@index([userId, kind])
}

model IntegrationConnection {
  id                  String              @id @default(cuid())
  provider            IntegrationProvider
  scope               IntegrationScope
  status              IntegrationStatus   @default(CONNECTED)
  userId              String?
  organizationId      String?
  externalAccountId   String?
  externalAccountName String?
  accessTokenEncrypted String
  refreshTokenEncrypted String?
  tokenExpiresAt      DateTime?
  metadata            Json?
  lastSyncedAt        DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([provider, userId])
  @@unique([provider, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([provider, scope])
  @@index([provider, organizationId, status])
  @@index([provider, userId, status])
}

model AiUsageEntry {
  id             String      @id @default(cuid())
  userId         String
  organizationId String?
  projectId      String?
  kind           AiUsageKind
  amount         Int
  createdAt      DateTime    @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([kind, createdAt])
  @@index([userId, kind, createdAt])
  @@index([organizationId, kind, createdAt])
}

model FreeAiEmailUsage {
  id        String   @id @default(cuid())
  email     String
  monthKey  String
  amount    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, monthKey])
  @@index([monthKey])
}
